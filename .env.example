NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# NEXT_PUBLIC_SUPABASE_ANON_KEY is also supported for older Supabase naming.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Report email delivery for /netlify/functions/send-report.js
# Add these in Netlify site settings > Environment variables.
RESEND_API_KEY=re_your_resend_api_key
REPORT_FROM_EMAIL=The Future Studio <reports@thefuturestudio.online>
REPORT_REPLY_TO=info@thefuturestudio.online
REPORT_BCC_EMAIL=info@thefuturestudio.online
